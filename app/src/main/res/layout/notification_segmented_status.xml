<?xml version="1.0" encoding="utf-8"?>
<!-- Frame height must match NotificationSegmentDimensions.compositeHeightDp(). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/segmented_status_root"
    android:layout_width="match_parent"
    android:layout_height="@dimen/segmented_notification_image_height"
    android:padding="0dp">

    <ImageView
        android:id="@+id/segmented_status_image"
        android:layout_width="@dimen/segmented_notification_image_width"
        android:layout_height="@dimen/segmented_notification_image_height"
        android:layout_gravity="start|center_vertical"
        android:adjustViewBounds="false"
        android:contentDescription="@string/background_usage_notification_title"
        android:scaleType="center" />
</FrameLayout>
