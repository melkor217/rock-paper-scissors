rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidMatchMode(mode) {
      return mode == 'BO3' || mode == 'BO5' || mode == 'BO10';
    }

    function modesAreDistinct(modes) {
      return modes.size() <= 1
        || (modes.size() == 2 && modes[0] != modes[1])
        || (modes.size() == 3
            && modes[0] != modes[1]
            && modes[0] != modes[2]
            && modes[1] != modes[2]);
    }

    function validQueueMatchModes(modes) {
      return modes is list
        && modes.size() >= 1
        && modes.size() <= 3
        && (modes.size() < 1 || isValidMatchMode(modes[0]))
        && (modes.size() < 2 || isValidMatchMode(modes[1]))
        && (modes.size() < 3 || isValidMatchMode(modes[2]))
        && modesAreDistinct(modes);
    }

    function validQueueMatchModeField(data) {
      return !('matchModes' in data) && !('matchMode' in data)
        || ('matchModes' in data && validQueueMatchModes(data.matchModes))
        || ('matchMode' in data && isValidMatchMode(data.matchMode));
    }

    /** Legacy clients omit matchModes; Cloud Functions default to BO3. */
    function validQueueWrite() {
      let data = request.resource.data;
      return data.keys().hasAll(['joinedAt', 'lastHeartbeatAt', 'elo', 'displayName'])
        && data.joinedAt is timestamp
        && data.lastHeartbeatAt is timestamp
        && data.elo is number
        && data.displayName is string
        && validQueueMatchModeField(data);
    }

    function validQueueHeartbeat() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastHeartbeatAt'])
        && request.resource.data.lastHeartbeatAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll([
          'displayName', 'elo', 'wins', 'losses', 'createdAt', 'lastSeen',
          'throwsRock', 'throwsPaper', 'throwsScissors'
        ])
        && request.resource.data.elo == 1000
        && request.resource.data.wins == 0
        && request.resource.data.losses == 0
        && (!('draws' in request.resource.data) || request.resource.data.draws == 0)
        && (!('moveTimeMs' in request.resource.data) || request.resource.data.moveTimeMs == 0)
        && (!('moveCount' in request.resource.data) || request.resource.data.moveCount == 0)
        && request.resource.data.throwsRock == 0
        && request.resource.data.throwsPaper == 0
        && request.resource.data.throwsScissors == 0
        && request.resource.data.lastSeen is timestamp;
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'elo', 'wins', 'losses', 'draws', 'activeMatchId',
          'moveTimeMs', 'moveCount',
          'throwsRock', 'throwsPaper', 'throwsScissors'
        ])
        && (!('lastSeen' in request.resource.data.diff(resource.data).changedKeys())
            || request.resource.data.lastSeen is timestamp);
    }

    match /presence/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['lastSeen'])
        && request.resource.data.lastSeen is timestamp;
      allow delete: if isOwner(userId);
    }

    match /queue/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && validQueueWrite();
      allow update: if isOwner(userId) && (validQueueWrite() || validQueueHeartbeat());
      allow delete: if isOwner(userId);
    }

    match /matches/{matchId} {
      allow read: if isSignedIn()
        && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid);
      allow write: if false;

      match /rounds/{roundNumber}/choices/{userId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/matches/$(matchId)).data.player1 == request.auth.uid
              || get(/databases/$(database)/documents/matches/$(matchId)).data.player2 == request.auth.uid);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['choice'])
          && request.resource.data.choice in ['ROCK', 'PAPER', 'SCISSORS']
          && get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'active'
          && int(roundNumber) == get(/databases/$(database)/documents/matches/$(matchId)).data.currentRound
          && (get(/databases/$(database)/documents/matches/$(matchId)).data.player1 == request.auth.uid
              || get(/databases/$(database)/documents/matches/$(matchId)).data.player2 == request.auth.uid);
        allow update, delete: if false;
      }

      match /rounds/{roundNumber}/timeoutRequests/{requestId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/matches/$(matchId)).data.player1 == request.auth.uid
              || get(/databases/$(database)/documents/matches/$(matchId)).data.player2 == request.auth.uid);
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.keys().hasAll(['requestedAt', 'userId'])
          && get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'active'
          && int(roundNumber) == get(/databases/$(database)/documents/matches/$(matchId)).data.currentRound
          && (get(/databases/$(database)/documents/matches/$(matchId)).data.player1 == request.auth.uid
              || get(/databases/$(database)/documents/matches/$(matchId)).data.player2 == request.auth.uid);
        allow update, delete: if false;
      }
    }
  }
}
