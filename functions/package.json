{
  "name": "functions",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.scripts.json",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions,firestore:rules,firestore:indexes",
    "lint": "eslint --ext .js,.ts .",
    "test": "npm run build && node --test lib/*.test.js",
    "backfill-last-seen": "npm run build && node lib/scripts/backfill-user-last-seen.js",
    "backfill-throw-stats": "npm run build && node lib/scripts/backfill-throw-stats.js",
    "backfill-move-timing": "npm run build && node lib/scripts/backfill-move-timing.js",
    "backfill-round-stats": "npm run build && node lib/scripts/backfill-round-stats.js",
    "backfill-round-end-reason": "npm run build && node lib/scripts/backfill-round-end-reason.js",
    "backfill-match-resolution": "npm run build && node lib/scripts/backfill-match-resolution.js"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  },
  "private": true
}
