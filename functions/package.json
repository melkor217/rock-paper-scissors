{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions,firestore:rules,firestore:indexes",
    "lint": "eslint --ext .js,.ts .",
    "test": "npm run build && node --test lib/game.test.js",
    "backfill-last-seen": "npm run build && node lib/scripts/backfill-user-last-seen.js"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  },
  "private": true
}
