{
  "name": "functions",
  "scripts": {
    "build": "node -e \"require('fs').copyFileSync('../shared/game-rules.json','src/game-rules.json')\" && tsc && node -e \"require('fs').copyFileSync('src/game-rules.json','lib/game-rules.json')\"",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions,firestore:rules,firestore:indexes",
    "lint": "eslint --ext .js,.ts .",
    "test": "npm run build && node --test lib/*.test.js"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  },
  "private": true
}
